# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/pozo-solidario

# Mercado Pago
MP_ACCESS_TOKEN=your_mercadopago_access_token
MP_PUBLIC_KEY=your_mercadopago_public_key
MP_WEBHOOK_SECRET=your_webhook_secret

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key

# App
NEXT_PUBLIC_BASE_URL=https://pozosolidario.com
NEXT_PUBLIC_MP_PUBLIC_KEY=your_mercadopago_public_key

# Admin
ADMIN_SECRET=your_admin_secret_key

# Cron
CRON_SECRET=your_cron_secret

# Precio por número (en pesos ARS)
NEXT_PUBLIC_PRICE_PER_NUMBER=1000
